@enduml

@startuml Class Diagram - Domain Models

title Class Diagram - Domain Models

' ===== USER CLASS =====
class User {
  - _id: ObjectId
  - email: string
  - name: string
  - phone: string
  - password: string
  - photo: string
  - role: 'admin' | 'user'
  - totalPdf: number
  - createdAt: Date
  - updatedAt: Date
  --
  + save(): Promise<User>
  + validatePassword(): boolean
}

' ===== VIDEO CLASS =====
class Video {
  - _id: ObjectId
  - caption: string
  - fileUrl: string
  - prediction: string (JSON)
  - status: 'processing' | 'completed' | 'failed'
  - user: ObjectId
  - telegramChatId: number
  - createdAt: Date
  - updatedAt: Date
  --
  + save(): Promise<Video>
  + updateStatus(status: string): void
  + updatePrediction(data: string): void
}

' ===== PREDICTION DATA CLASS =====
class PredictionData {
  - predictions: Prediction[]
  - summary: Summary
  - video_info: VideoInfo
  --
  + getPredictionCount(): number
  + getMostCommonApp(): string
  + getMostCommonAction(): string
}

class Prediction {
  - time_range: string
  - app: string
  - app_confidence: number
  - action: string
  - action_confidence: number
  --
  + isHighConfidence(): boolean
}

class Summary {
  - total_chunks: number
  - most_common_app: string
  - most_common_action: string
  - avg_app_confidence: number
  - avg_action_confidence: number
}

class VideoInfo {
  - duration_seconds: number
  - num_chunks: number
  - chunk_duration: number
}

' ===== AUTHENTICATION CLASS =====
class AuthContext {
  - user: User
  - firebaseUser: FirebaseUser
  - loading: boolean
  - isAuthenticated: boolean
  --
  + login(email, password): Promise<boolean>
  + logout(): Promise<void>
  + createUser(email, password): Promise<any>
  + updateUser(name, photo): Promise<void>
}

' ===== CONTROLLER CLASSES =====
class VideoController {
  --
  + createVideo(req, res): Promise<void>
  + getAllVideos(req, res): Promise<void>
  + getVideoById(req, res): Promise<void>
  + generateReport(req, res): Promise<void>
  + streamVideo(req, res): Promise<void>
  + deleteVideo(req, res): Promise<void>
}

class UserController {
  --
  + createUser(req, res): Promise<void>
  + getAllUsers(req, res): Promise<void>
  + getUserById(req, res): Promise<void>
  + updateUser(req, res): Promise<void>
  + deleteUser(req, res): Promise<void>
}

' ===== SERVICE CLASSES =====
class VideoService {
  --
  + createVideo(data): Promise<Video>
  + uploadToMinIO(file): Promise<string>
  + downloadFromMinIO(fileUrl): Promise<Buffer>
  + processPrediction(videoId): Promise<void>
  + callAIPrediction(videoPath): Promise<any>
  + updateVideoStatus(id, status): Promise<void>
  + generateAIReport(videoId, type): Promise<string>
}

class UserService {
  --
  + createUser(data): Promise<User>
  + findUserByEmail(email): Promise<User>
  + getAllUsers(): Promise<User[]>
  + updateUser(id, data): Promise<User>
  + deleteUser(id): Promise<void>
}

class LLMService {
  --
  + generateReport(predictions, type): Promise<string>
  + callOllama(prompt): Promise<string>
  + formatPrompt(data, type): string
}

' ===== TELEGRAM BOT CLASS =====
class TelegramBot {
  - bot: Telegraf
  - userProcessing: Map<number, string>
  --
  + handleStart(ctx): Promise<void>
  + handleHelp(ctx): Promise<void>
  + handleStatus(ctx): Promise<void>
  + handleVideo(ctx): Promise<void>
  + uploadToMinIO(file): Promise<string>
  + processPrediction(videoId, chatId): Promise<void>
  + sendResults(chatId, results): Promise<void>
}

' ===== RELATIONSHIPS =====
Video "0..*" --> "0..1" User : owned by
Video "1" *-- "1" PredictionData : contains
PredictionData "1" *-- "many" Prediction : has
PredictionData "1" *-- "1" Summary : has
PredictionData "1" *-- "1" VideoInfo : has

VideoController --> VideoService : uses
UserController --> UserService : uses
VideoService --> LLMService : uses

VideoService ..> Video : manages
UserService ..> User : manages

TelegramBot ..> VideoService : uses
TelegramBot ..> Video : creates

@enduml

@startuml Sequence Diagram - Video Upload (Web)

title Sequence Diagram - Video Upload via Web Interface

actor User
participant "Web Frontend" as Web
participant "Video Controller" as Ctrl
participant "Video Service" as Svc
participant "MinIO Storage" as MinIO
participant "MongoDB" as DB
participant "AI Service" as AI

User -> Web: Upload MP4 video
activate Web

Web -> Web: Validate file (MP4)
Web -> Ctrl: POST /videos/create-video\n(FormData with file)
activate Ctrl

Ctrl -> Ctrl: Save to temp file
Ctrl -> MinIO: Upload video
activate MinIO
MinIO --> Ctrl: File URL
deactivate MinIO

Ctrl -> Ctrl: Delete temp file

Ctrl -> DB: Save video metadata\n(status: processing)
activate DB
DB --> Ctrl: Video ID
deactivate DB

Ctrl --> Web: Upload Success + Video ID
deactivate Ctrl

Web --> User: Show success message\n"Processing started"
deactivate Web

' Background Processing
group Background AI Analysis
  Ctrl -> Svc: Start background processing
  activate Svc
  
  Svc -> MinIO: Download video
  activate MinIO
  MinIO --> Svc: Video file
  deactivate MinIO
  
  Svc -> Svc: Save to temp file
  
  Svc -> AI: POST /predict\n(video file)
  activate AI
  AI -> AI: Process video\n(3s chunks)
  AI -> AI: Detect apps & actions
  AI --> Svc: Prediction JSON
  deactivate AI
  
  Svc -> DB: Update video\n(prediction + status: completed)
  activate DB
  DB --> Svc: Success
  deactivate DB
  
  Svc -> Svc: Delete temp file
  deactivate Svc
end

' Auto-refresh
loop Every 5 seconds (while processing)
  Web -> Ctrl: GET /videos
  activate Ctrl
  Ctrl -> DB: Fetch videos
  activate DB
  DB --> Ctrl: Video list
  deactivate DB
  Ctrl --> Web: Updated status
  deactivate Ctrl
  Web -> Web: Update UI
end

Web --> User: Show "Completed" status

@enduml

