@startuml Screen Activity Analyzer - System Architecture

title Screen Activity Analyzer - UML Diagrams

' ===== COMPONENT DIAGRAM =====
package "Frontend - React Application" {
  component [Web Interface] as Web
  component [Authentication] as Auth
  component [Video Dashboard] as Dashboard
  component [Video Player] as Player
  component [Report Generator] as ReportUI
  
  package "Context & Hooks" {
    component [AuthContext] as AuthCtx
    component [useAxiosSecure] as AxiosHook
  }
  
  package "Firebase" {
    component [Firebase Auth] as Firebase
  }
}

package "Backend - Node.js/Express API" {
  component [API Gateway] as API
  component [Auth Middleware] as AuthMW
  component [Video Controller] as VideoCtrl
  component [User Controller] as UserCtrl
  component [Video Service] as VideoSvc
  component [User Service] as UserSvc
  component [LLM Service] as LLMSvc
  component [Error Handler] as ErrorHandler
}

package "External Services" {
  component [Telegram Bot] as TgBot
  database [MongoDB] as DB
  storage [MinIO Storage] as MinIO
  component [AI Prediction Service\n(Python Flask)] as AIPrediction
  component [Ollama LLM] as Ollama
}

